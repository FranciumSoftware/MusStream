sourcemanager.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\appMusStream.dir\build.make CMakeFiles/appMusStream.dir/sourcemanager.cpp.i
.PHONY : sourcemanager.cpp.i

sourcemanager.s: sourcemanager.cpp.s
.PHONY : sourcemanager.s

# target to generate assembly for a file
sourcemanager.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\appMusStream.dir\build.make CMakeFiles/appMusStream.dir/sourcemanager.cpp.s
.PHONY : sourcemanager.cpp.s

